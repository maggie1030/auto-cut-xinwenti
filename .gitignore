.DS_Store
*.log
Thumbs.db
__pycache__/
*.py[cod]

# 成片与中间产物（体积大，本地生成即可）
video-pipeline/out/

# 依赖
video-pipeline/node_modules/
video-pipeline/.env.venv/

# 个人素材（体积大）；保留演示用 _demo 目录
video-pipeline/assets/video/*
!video-pipeline/assets/video/_demo/
!video-pipeline/assets/video/_demo/**
video-pipeline/assets/audio/*
!video-pipeline/assets/audio/_demo/
!video-pipeline/assets/audio/_demo/**

# 本地成片任务 JSON（常含个人素材文件名与未公开文案）；保留 *example* 与 caption-002 模板
video-pipeline/copy/final-jobs/final-[0-9]*.json
!video-pipeline/copy/final-jobs/final-job.example.json
video-pipeline/copy/caption-jobs/caption-0*.json
!video-pipeline/copy/caption-jobs/caption-002.json
